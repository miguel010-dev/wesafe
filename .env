# Copie este arquivo para ".env" (ou exporte as variáveis) antes de rodar em produção.

# Chave secreta usada para assinar os tokens JWT — troque por algo forte e aleatório.
JWT_SECRET_KEY=wesafe-troque-esta-chave-em-producao-2026

# Banco de dados (por padrão usa SQLite local, ótimo para desenvolvimento).
DATABASE_URL=sqlite:///wesafe.db

# Token da Mapbox — opcional. Usado apenas para geocodificação reversa (nome de bairro/cidade)
# ao salvar uma denúncia no backend. Sem ele, o app continua funcionando normalmente,
# apenas sem preencher bairro/cidade automaticamente nas denúncias.
MAPBOX_TOKEN=pk.eyJ1IjoibWlndXdsMDI4NyIsImEiOiJjbWl3bTRsa3MyY3Y3M2Rwd3VtM3ZleGdrIn0.uTdjZpweZcDh9qfm89TyZw

# Roteador OSRM usado para calcular as rotas reais (não precisa de chave).
OSRM_BASE_URL=https://routing.openstreetmap.de

# Configuração do servidor Flask.
FLASK_DEBUG=false
HOST=127.0.0.1
PORT=5000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=nebulaossac@gmail.com
SMTP_PASS=ddbkdukgbqyfamez
SMTP_USE_TLS=true
SMTP_FROM=WeSafe <nebulaossac@gmail.com>
# ---------- Login com Google (Google Identity Services) ----------
# Client ID do OAuth 2.0 (tipo "Aplicativo da Web"). Isso NÃO é segredo — ele é
# enviado ao navegador em toda tela de login e o próprio Google o valida.
# Cole aqui o Client ID mostrado no Google Cloud Console > APIs e serviços >
# Credenciais. As origens JavaScript autorizadas devem incluir o domínio de
# onde o app roda (ex.: http://127.0.0.1:5000 e https://SEU-APP.onrender.com).
#
# IMPORTANTE: esse fluxo (verificação de ID Token no backend) NUNCA usa a
# "client secret" — não a coloque em nenhum arquivo deste projeto. Se uma
# client secret chegou a ser exposta (ex.: colada em um chat, commitada por
# engano), gere uma nova em "Chaves secretas do cliente" e desative a antiga.
GOOGLE_CLIENT_ID=58120082206-c82iubbdhe9s5v6lu2k69u31b6j7qpe8.apps.googleusercontent.com

ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador WeSafe
